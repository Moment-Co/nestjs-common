{
  "name": "@momentco/nestjs-common",
  "version": "0.1.1",
  "description": "Shared NestJS infrastructure primitives for Momentco services",
  "packageManager": "pnpm@9.15.4",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepare": "pnpm run build",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "jest --config jest.config.ts --testPathPattern=unit --passWithNoTests",
    "test:integration": "jest --config jest.config.ts --testPathPattern=integration --passWithNoTests",
    "test:all": "jest --config jest.config.ts --forceExit"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "typeorm": "^0.3.0"
  },
  "devDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nestjs/typeorm": "^11.0.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "jest": "^29.7.0",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.7",
    "@types/winston": "^2.4.4",
    "axios": "^1.6.0",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typeorm": "^0.3.17",
    "typescript": "^5.3.3",
    "winston": "^3.11.0",
    "uuid": "^9.0.0",
    "zod": "^3.22.4"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "winston": "^3.11.0",
    "uuid": "^9.0.0",
    "zod": "^3.22.4"
  }
}
